{
  "name": "figma-dev-cli",
  "version": "0.1.1",
  "description": "Token-efficient CLI for Figma Desktop MCP server. Built for AI agents and developers.",
  "type": "module",
  "bin": {
    "figma-dev": "./bin/figma-dev.js"
  },
  "files": [
    "bin/",
    "dist/",
    "skill/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node bin/figma-dev.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "figma",
    "cli",
    "mcp",
    "design",
    "model-context-protocol"
  ],
  "author": "Gerard Dang",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.0",
    "chalk": "^5.0.0",
    "ora": "^9.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  }
}
